{
  "rewrites": [
    { "source": "/app", "destination": "/zenda-app.html" },
    { "source": "/book/:slug", "destination": "/zenda-booking.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
